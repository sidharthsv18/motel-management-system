  "deployment": {
    "steps": [
      {
        "id": 1,
        "title": "Wait for RDS Database",
        "description": "RDS database is initializing. Check status in AWS console.",
        "command": "aws rds describe-db-instances --db-instance-identifier motel-management-db --region ap-south-1 --profile motel-deploy",
        "status": "in_progress",
        "timeToComplete": "5-15 minutes"
      },
      {
        "id": 2,
        "title": "SSH into EC2 Instance",
        "description": "Connect to the EC2 instance using SSH",
        "command": "ssh -i motel-management-key.pem ubuntu@3.110.24.107",
        "status": "ready",
        "timeToComplete": "1 minute"
      },
      {
        "id": 3,
        "title": "Update System",
        "description": "Update Ubuntu packages",
        "command": "sudo apt update && sudo apt upgrade -y",
        "status": "ready",
        "timeToComplete": "5 minutes"
      },
      {
        "id": 4,
        "title": "Install Dependencies",
        "description": "Install Node.js, npm, and other tools",
        "command": "curl -fsSL https://deb.nodesource.com/setup_18.x | sudo -E bash - && sudo apt install -y nodejs npm git pm2",
        "status": "ready",
        "timeToComplete": "10 minutes"
      },
      {
        "id": 5,
        "title": "Clone Application",
        "description": "Clone the motel management application",
        "command": "cd /home/ubuntu && git clone https://github.com/sidharthsv18/motel-management-system.git && cd motel-management-system",
        "status": "ready",
        "timeToComplete": "2 minutes"
      },
      {
        "id": 6,
        "title": "Install Node Dependencies",
        "description": "Install npm packages for server and client",
        "command": "npm run setup",
        "status": "ready",
        "timeToComplete": "10 minutes"
      },
      {
        "id": 7,
        "title": "Configure RDS Endpoint",
        "description": "Update .env file with RDS endpoint (once available)",
        "command": "echo 'DB_HOST={RDS_ENDPOINT}' > .env",
        "status": "blocked",
        "blockedBy": "RDS initialization"
      },
      {
        "id": 8,
        "title": "Initialize Database",
        "description": "Run database initialization script",
        "command": "psql -h {RDS_ENDPOINT} -U motel_admin -d motel_db -f database/init.sql",
        "status": "blocked",
        "blockedBy": "RDS initialization"
      },
      {
        "id": 9,
        "title": "Start Application (PM2)",
        "description": "Start Node.js backend and React frontend with PM2",
        "command": "pm2 start npm --name 'motel-backend' -- start",
        "status": "ready",
        "timeToComplete": "2 minutes"
      },
      {
        "id": 10,
        "title": "Configure Domain (Optional)",
        "description": "Point domain to Elastic IP",
        "command": "Update DNS A record to 3.110.24.107",
        "status": "ready",
        "timeToComplete": "varies"
      }
